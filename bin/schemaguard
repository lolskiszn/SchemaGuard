#!/usr/bin/env node
/**
 * CLI - Command-line interface for SchemaGuard
 * Supports config file: .schemaguard.json, schemaguard.config.js
 */

const { readFileSync, writeFileSync } = require('fs');
const { parseSql, parseSchema } = require('../lib/parser/index.js');
const { generateAllTypes } = require('../lib/generator/guard-builder.js');
const { mergeConfig, findConfig } = require('../lib/config.js');

const args = process.argv.slice(2);

// Quick exit for init - before normal config loading
if (args[0] === 'init') {
  (async () => {
    const { init } = require('../lib/init.js');
    await init();
  })();
  process.exit(0);
}

// Build config from file + CLI args
const fileConfig = findConfig() || {};
const CLIOpts = {};

for (let i = 0; i < args.length; i++) {
  const arg = args[i];
  if (arg === '-i' || arg === '--input') CLIOpts.input = args[++i];
  else if (arg === '-o' || arg === '--output') CLIOpts.output = args[++i];
  else if (arg === '-f' || arg === '--format') CLIOpts.format = args[++i];
  else if (arg === '-v' || arg === '--verbose') CLIOpts.verbose = true;
  else if (arg === '--include') CLIOpts.include = args[++i].split(',');
  else if (arg === '--exclude') CLIOpts.exclude = args[++i].split(',');
  else if (arg === '--prisma') CLIOpts.format = 'prisma';
  else if (arg === '--fix') CLIOpts.fix = true;
  else if (arg === '--report') CLIOpts.report = true;
}

// Fix mode: auto-heal known SQL syntax issues
if (CLIOpts.fix && CLIOpts.input) {
  let sql = require('fs').readFileSync(CLIOpts.input, 'utf-8');
  
  // Fix common SQL syntax issues
  const fixes = [
    { pattern: /SERIAL\s+AUTO_INCREMENT/gi, replacement: 'SERIAL' },
    { pattern: /DOUBLE PRECISION/gi, replacement: 'DOUBLE' },
    { pattern: /BIGSERIAL\s+AUTO_INCREMENT/gi, replacement: 'BIGSERIAL' },
    { pattern: /CHARACTER\s+VARYING/gi, replacement: 'VARCHAR' },
    { pattern: /CHAR\s+VARYING/gi, replacement: 'VARCHAR' },
    { pattern: /WITH\s+TIME\s+ZONE/gi, replacement: 'WITH TIME ZONE' },
    { pattern: /WITHOUT\s TIME\s+ZONE/gi, replacement: 'WITHOUT TIME ZONE' },
    { pattern: /timestamp\s+without/gi, replacement: 'TIMESTAMP WITHOUT' },
    { pattern: /timestamp\s+with/gi, replacement: 'TIMESTAMP WITH' },
  ];
  
  let fixed = false;
  for (const f of fixes) {
    if (f.pattern.test(sql)) {
      sql = sql.replace(f.pattern, f.replacement);
      fixed = true;
    }
  }
  
  if (fixed) {
    require('fs').writeFileSync(CLIOpts.input + '.bak', require('fs').readFileSync(CLIOpts.input, 'utf-8'));
    require('fs').writeFileSync(CLIOpts.input, sql);
    console.log('✅ Auto-fixed SQL syntax issues (backup saved to *.bak)');
  }
}

// Drift report mode: show what would change
if (CLIOpts.report && CLIOpts.input) {
  const sql = require('fs').readFileSync(CLIOpts.input, 'utf-8');
  const { parseSchema } = require('../lib/parser/index.js');
  const { generateTypeDefs } = require('../lib/generator/guard-builder.js');
  const prevTypes = CLIOpts.output && require('fs').existsSync(CLIOpts.output) 
    ? require('fs').readFileSync(CLIOpts.output, 'utf-8') 
    : null;
  
  const ast = parseSchema(sql, CLIOpts.format || 'sql');
  const newTypes = generateTypeDefs(ast);
  
  console.log('\n╔════════════════════════════════════════╗');
  console.log('║       Schema Drift Report           ║');
  console.log('╚════════════════════════════════════════╝\n');
  
  // Check for additions
  const prevLines = prevTypes ? prevTypes.split('\n').filter(l => l.match(/^export (type|const)/)) : [];
  const newLines = newTypes.split('\n').filter(l => l.match(/^export (type|const)/));
  
  const prevNames = prevLines.map(l => l.match(/(\w+)\s*=/)?.[1] || l.match(/(\w+)\s*=/)?.[1]).filter(Boolean);
  const newNames = newLines.map(l => l.match(/(\w+)\s*=/)?.[1] || l.match(/(\w+)\s*=/)?.[1]).filter(Boolean);
  
  const added = newNames.filter(n => !prevNames.includes(n));
  const removed = prevNames.filter(n => !newNames.includes(n));
  
  if (added.length) console.log('📦 New types: ' + added.join(', '));
  if (removed.length) console.log('🗑️  Removed: ' + removed.join(', '));
  if (!added.length && !removed.length) console.log('✅ No type changes detected');
  
  console.log('\nRun "schemaguard generate" to update types.');
  process.exit(0);
}

const config = mergeConfig(CLIOpts);

// Help
if (args.length === 0 || args[0] === '--help' || args[0] === '-h') {
  console.log(`
SchemaGuard - Generate TypeScript type guards from database schemas

Usage: schemaguard [command] [options]

Commands:
  generate    Generate TypeScript type guards from SQL schema
  init       Interactive setup wizard

Options:
  -i, --input <file>   Input SQL schema file (required)
  -o, --output <file>  Output TypeScript file
  -f, --format        Output format: esm or cjs (default: esm)
  -v, --verbose       Verbose output
  --include <tables>  Comma-separated tables to include
  --exclude <tables>  Comma-separated tables to exclude
  --fix              Auto-fix common SQL syntax issues
  --prisma          Parse as Prisma schema

Config (place .schemaguard.json in project root):
  include: ["users", "posts"]     # Tables to process
  exclude: ["_prisma_*"]         # Tables to skip
  output.format: "esm"           # esm or cjs
  output.namespace: "Schema"     # TypeScript namespace

Example:
  schemaguard generate -i schema.sql -o guards.ts
  cat .schemaguard.json
  `);
  process.exit(0);
}

if (args[0] === '--version') {
  console.log('schemaguard v1.0.0');
  process.exit(0);
}

if (args[0] === 'init') {
  (async () => {
    const { init } = require('../lib/init.js');
    await init();
  })();
  process.exit(0);
}

if (args[0] !== 'generate') {
  console.error('Error: Unknown command. Use --help');
  process.exit(1);
}

if (!config.input) {
  console.error('Error: --input is required');
  process.exit(1);
}

try {
  if (config.verbose) console.error('Reading:', config.input);
  if (config.include) console.error('Including:', config.include.join(', '));
  if (config.exclude) console.error('Excluding:', config.exclude.join(', '));

  const sql = readFileSync(config.input, 'utf-8');
  if (config.verbose) console.error('Parsing SQL...');

  let tables = parseSchema(sql, CLIOpts.format || 'sql');

  // Apply include/exclude filters only when explicitly provided (check for real array, not just config defaults)
  if (CLIOpts.include && Array.isArray(CLIOpts.include) && CLIOpts.include.length > 0) {
    tables = tables.filter(t => CLIOpts.include.includes(t.name));
  }
  if (CLIOpts.exclude && Array.isArray(CLIOpts.exclude) && CLIOpts.exclude.length > 0) {
    tables = tables.filter(t => !CLIOpts.exclude.includes(t.name));
  }

  if (tables.length === 0) {
    console.error('Warning: No tables match filter');
    process.exit(1);
  }

  let guards = generateAllTypes(tables, config);

  if (config.format === 'cjs') {
    guards = guards.replace(/export /g, 'module.exports.');
    guards = guards.replace(/import\{/g, 'const {').replace(/} from/g, '} = require(');
  }

  if (config.output) {
    writeFileSync(config.output, `// Generated by SchemaGuard\n${guards}`);
    if (config.verbose) console.error('Written:', config.output);
    console.log(`✓ ${tables.length} type guard(s) → ${config.output}`);
  } else {
    console.log(guards);
  }
} catch (err) {
  console.error('Error:', err.message);
  process.exit(1);
}
